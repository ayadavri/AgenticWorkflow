# Production — copy to terraform.tfvars and set real values.
#
# aws_region / aws_profile / aws_account_id: set to production account.

# aws_region     = "us-east-1"
# aws_profile    = "prod-session"
# aws_account_id = "111111111111"

# tags = {
#   Environment = "prod"
# }

# RI Core (default in variables.tf mirrors test → prod)
# ri_core_base_url = "https://prod-ri-core.residentinterface.com"

# dynamodb_table_name                      = "DisputeCore"
# dynamodb_stream_enabled                  = true
# dispute_core_stream_lambda_function_name = "dispute-core-ddb-stream"

# CDC → datalake (Kinesis + Firehose); set prod datalake bucket
dispute_core_firehose_s3_bucket = "YOUR-PROD-DATALAKE-BUCKET"

# EventBridge dispute-event-bus → platform FIFO queues (override if ARNs differ)
# dispute_event_bus_opensearch_target_sqs_arn = "arn:aws:sqs:us-east-1:ACCOUNT_ID:projections.fifo"
# dispute_event_bus_temporal_target_sqs_arn   = "arn:aws:sqs:us-east-1:ACCOUNT_ID:workflow.fifo"

# disputes-core-invokeAgenticAI → dispute-agent.fifo → dispute-agent-analysis (must match Lambda timeout)
# dispute_agent_fifo_visibility_timeout_seconds = 300
# dispute_analysis_lambda_attach_sqs           = true

# Judgment Lambda: schedule off by default in prod; set true (and optional cron) to enable
# dispute_judgment_lambda_enable_daily_schedule  = true
# dispute_judgment_lambda_schedule_expression     = "rate(2 hours)"

# Staging bucket (-prod avoids global name collision with case-dispute-analysis)
# dispute_judgment_lambda_s3_bucket_names  = ["case-dispute-analysis-prod"]
# create_case_dispute_analysis_s3_bucket   = true
#
# dispute_analysis_lambda_environment_extra = {
#   CONFIG_S3_BUCKET                = "case-dispute-analysis-prod"
#   CASE_DISPUTE_ANALYSIS_S3_BUCKET = "case-dispute-analysis-prod"
# }
# dispute_judgment_lambda_environment_extra = {
#   CONFIG_S3_BUCKET                = "case-dispute-analysis-prod"
#   CASE_DISPUTE_ANALYSIS_S3_BUCKET = "case-dispute-analysis-prod"
# }

# Optional overrides
# dispute_agent_fifo_queue_name                 = "dispute-agent.fifo"
# dispute_analysis_lambda_s3_read_bucket_names = ["resident-documents-PRODUCTION-ID"]
# create_case_dispute_analysis_s3_bucket        = false  # if bucket already exists
